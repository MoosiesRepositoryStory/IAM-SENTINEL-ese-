[
  {
    "name": "AdminAccess",
    "kind": "aws_managed",
    "document": {
      "Version": "2012-10-17",
      "Statement": [
        { "Effect": "Allow", "Action": "*", "Resource": "*" }
      ]
    }
  },
  {
    "name": "InternEscalation",
    "kind": "inline",
    "document": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Effect": "Allow",
          "Action": ["iam:PassRole", "iam:CreateAccessKey", "iam:AttachUserPolicy"],
          "Resource": "*"
        }
      ]
    }
  },
  {
    "name": "DeployPipeline",
    "kind": "managed",
    "document": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Effect": "Allow",
          "NotAction": ["cloudtrail:StopLogging"],
          "Resource": "*"
        }
      ]
    }
  },
  {
    "name": "ReadOnlyS3",
    "kind": "managed",
    "document": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Effect": "Allow",
          "Action": ["s3:GetObject", "s3:ListBucket"],
          "Resource": ["arn:aws:s3:::acme-reports/*"]
        }
      ]
    }
  }
]

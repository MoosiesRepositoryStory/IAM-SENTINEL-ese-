# --- IAM Sentinel configuration ------------------------------------------------
# Copy to .env and adjust. All values have sensible defaults for local/demo use.

# Database. SQLite by default; point at Postgres for the "serious" demo.
# DATABASE_URL=postgresql+psycopg://sentinel:sentinel@db:5432/sentinel
DATABASE_URL=sqlite:///data/sentinel.db

# Where the SQLite DB and JSON/CSV report artifacts live.
DATA_DIR=data
REPORTS_DIR=data/reports

# Flask session signing key — CHANGE for anything internet-facing.
SECRET_KEY=dev-insecure-change-me

# Run scans inline (Phase 0/1). Set false in Phase 2 to use the RQ worker.
SYNC_JOBS=true

# --- Phase 2+ (unused until then) ---------------------------------------------
# REDIS_URL=redis://redis:6379/0
